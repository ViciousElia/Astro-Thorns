---
export const prerender = false; // Required: disable static generation
import { getChapterData } from '../../lib/db';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NarrativeLayout from '../../layouts/NarrativeLayout.astro';

const { chapter } = Astro.params;
const chapterPath = Array.isArray(chapter) ? chapter.join('/') : chapter || '0';

// Database lookup - this runs server-side at request time
const result = await getChapterData(chapterPath);

// Redirect pattern
if (result.chapter && result.chapter+'' !== chapterPath+'') {
  return Astro.redirect(`/p/${result.chapter}`, 302); // or 302
}
// Normal render
const { content, title, meta, arc, book, place, date } = result;
---

<BaseLayout title={title || 'Chapter '+chapterPath} meta={meta || ''}>
  <NarrativeLayout arc={arc || ''} book={book || ''} place={place || ''} date={date || ''} chapter={chapter || chapterPath} nav={result.nav} title={title}>
    <Fragment set:html={content} />
  </NarrativeLayout>
</BaseLayout>
